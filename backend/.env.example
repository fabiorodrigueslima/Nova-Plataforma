# Servidor
PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# Seguranca
JWT_SECRET=coloque-uma-chave-longa-e-aleatoria-aqui

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/nome_do_banco

# Email de recuperacao de senha
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app-google

# Google OAuth
# Cole aqui o mesmo ID do cliente OAuth configurado no frontend.
# Formato esperado: 1234567890-abcxyz.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# Uploads em producao
# Se deixar vazio, o backend usa backend/uploads apenas em desenvolvimento.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
